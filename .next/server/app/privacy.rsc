5:["$","main",null,{"className":"container mx-auto px-4 md:px-10 lg:px-15 py-12 text-gray-700","children":[["$","h1",null,{"className":"text-3xl font-bold mb-8","children":"Privacy Policy"}],["$","p",null,{"className":"mb-6","children":["This Privacy Policy describes how ",["$","strong",null,{"children":"UAE IPTV BOX"}]," (“we,” “our,” or “us”) handles information when you access and use our website. By using this website, you agree to the terms outlined in this policy."]}],["$","h2",null,{"className":"text-xl font-semibold mt-10 mb-3","children":"1. Information We Collect"}],["$","p",null,{"className":"mb-4","children":"We do not require users to create accounts, register, or submit personal information to browse our website. We do not intentionally collect personally identifiable information from visitors."}],["$","p",null,{"className":"mb-6","children":"However, our hosting infrastructure may automatically collect limited technical data such as Internet Protocol (IP) address, browser type, device information, pages visited, and access times. This data is used strictly for security, performance monitoring, and website functionality."}],["$","h2",null,{"className":"text-xl font-semibold mt-10 mb-3","children":"2. Voluntarily Provided Information"}],["$","p",null,{"className":"mb-6","children":["If you contact us through our ",["$","strong",null,{"children":"/contact"}]," page or via WhatsApp, you may voluntarily provide information such as your name, phone number, email address, or message details. This information is used solely to respond to inquiries, provide support, or process requests."]}],["$","h2",null,{"className":"text-xl font-semibold mt-10 mb-3","children":"3. Purchases & External Communication"}],["$","p",null,{"className":"mb-4","children":"Our website displays product and service information, including TV boxes and IPTV subscription services. Purchases are not completed directly on this website."}],["$","p",null,{"className":"mb-6","children":"Users may be redirected to our official WhatsApp channel to finalize orders and payment arrangements. Any information shared via WhatsApp is governed by WhatsApp’s own Privacy Policy."}],["$","h2",null,{"className":"text-xl font-semibold mt-10 mb-3","children":"4. Cookies & Tracking Technologies"}],["$","p",null,{"className":"mb-4","children":"We currently do not use cookies, advertising trackers, behavioral profiling tools, or similar technologies designed to monitor visitor activity."}],["$","p",null,{"className":"mb-6","children":"If analytics or measurement services (such as Google Analytics or similar tools) are implemented in the future, this Privacy Policy will be updated to reflect those changes."}],["$","h2",null,{"className":"text-xl font-semibold mt-10 mb-3","children":"5. Third-Party Services"}],["$","p",null,{"className":"mb-6","children":"We do not share personal information with third parties. Our website operates independently. If third-party integrations or tools are added in the future, their usage and data practices will be disclosed here."}],["$","h2",null,{"className":"text-xl font-semibold mt-10 mb-3","children":"6. Data Security"}],["$","p",null,{"className":"mb-6","children":"We implement reasonable technical and organizational measures to protect our website and prevent unauthorized access. Since we do not actively collect or store sensitive personal data, risks related to data breaches are minimized."}],["$","h2",null,{"className":"text-xl font-semibold mt-10 mb-3","children":"7. International Data Processing"}],["$","p",null,{"className":"mb-6","children":"Our website is hosted in Bangladesh but primarily intended for users in the United Arab Emirates (UAE). By using this website, you acknowledge that technical data may be processed in Bangladesh."}],"$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16"]}]
